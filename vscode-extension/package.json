{
  "publisher": "BrettYoung",
  "name": "codeweave",
  "displayName": "CodeWeave",
  "description": "Visualize and restore Weave trace runs inside VSCode",
  "version": "0.0.39",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cdweave-sidebar",
          "title": "CodeWeave",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "cdweave-sidebar": [
        {
          "id": "cdweaveTraceTree",
          "name": "Trace Runs"
        },
        {
          "id": "cdweaveAllTraces",
          "name": "Selected Traces"
        },
        {
          "id": "cdweaveTraceDetail",
          "name": "Trace Detail"
        }
      ]
    },
    "commands": [
      {
        "command": "cdweave.selectTrace",
        "title": "Select CDWeave Trace"
      },
      {
        "command": "cdweave.show",
        "title": "CodeWeave: Show Panel",
        "icon": "$(pulse)"
      },
      {
        "command": "cdweave.clearFocus",
        "title": "CDWeave: Clear Highlight"
      },
      {
        "command": "cdweave.openTraceUrl",
        "title": "Open in Weave",
        "icon": "$(link-external)"
      },
      {
        "command": "cdweave.restoreRunCode",
        "title": "Restore run code",
        "icon": "$(history)"
      },
      {
        "command": "cdweave.restoreMainCode",
        "title": "Back to HEAD",
        "icon": "$(discard)"
      },
      {
        "command": "cdweave.selectProject",
        "title": "Select Project",
        "icon": "$(list-flat)"
      },
      {
        "command": "cdweave.unlockFiles",
        "title": "CodeWeave: Unlock Files"
      },
      {
        "command": "cdweave.copyRunTraces",
        "title": "Copy Traces",
        "icon": "$(copy)"
      },
      {
        "command": "cdweave.copyTrace",
        "title": "Copy Trace",
        "icon": "$(copy)"
      },
      {
        "command": "cdweave.goToCallSite",
        "title": "Go to Call Site",
        "icon": "$(target)"
      }
    ],
    "keybindings": [
      {
        "command": "cdweave.clearFocus",
        "key": "escape",
        "when": "editorTextFocus"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "cdweave.show",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "cdweave.selectProject",
          "when": "view == cdweaveTraceTree",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "cdweave.openTraceUrl",
          "when": "view =~ /cdweaveTraceTree|cdweaveAllTraces/ && viewItem == traceCallWithUrl",
          "group": "inline"
        },
        {
          "command": "cdweave.restoreRunCode",
          "when": "view == cdweaveTraceTree && viewItem == traceRunWithSnapshot",
          "group": "inline@1"
        },
        {
          "command": "cdweave.copyRunTraces",
          "when": "view == cdweaveTraceTree && viewItem =~ /traceRun/",
          "group": "inline@2"
        },
        {
          "command": "cdweave.copyTrace",
          "when": "view =~ /cdweaveTraceTree|cdweaveAllTraces/ && viewItem =~ /traceCall/",
          "group": "inline"
        },
        {
          "command": "cdweave.goToCallSite",
          "when": "view =~ /cdweaveTraceTree|cdweaveAllTraces/ && viewItem =~ /traceCall/",
          "group": "inline"
        }
      ]
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  }
}
